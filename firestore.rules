rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'tardhyip@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'unit', 'image', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() <= 20 &&
             data.image is string && data.image.size() > 0 && data.image.size() <= 2048;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             (!data.keys().hasAny(['accessibilityProfile']) || (data.accessibilityProfile is string && data.accessibilityProfile.size() <= 20)) &&
             data.email == request.auth.token.email;
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true; 
      
      allow create: if isAdmin() && 
                    isValidProduct(incoming()) && 
                    incoming().createdAt == request.time;
                    
      allow update: if isAdmin() && 
                    isValidProduct(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'unit', 'description', 'category', 'image', 'farmer', 'location', 'organic', 'farmToTable', 'updatedAt']) &&
                    (!incoming().keys().hasAny(['updatedAt']) || incoming().updatedAt == request.time);
                    
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && 
                    isValidUser(incoming()) && 
                    incoming().createdAt == request.time;
                    
      allow update: if isOwner(userId) && 
                    isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt', 'accessibilityProfile']) &&
                    (!incoming().keys().hasAny(['updatedAt']) || incoming().updatedAt == request.time);
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
